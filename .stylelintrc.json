{
    "extends": ["stylelint-config-standard-scss", "stylelint-config-css-modules"],
    "rules": {
        "selector-class-pattern": [
            "^[a-z][a-zA-Z0-9]*(_[a-zA-Z0-9]+)*$",
            {
                "message": "Expected class selector to be camelCase or snake_case"
            }
        ]
    }
}
